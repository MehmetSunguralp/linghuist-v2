{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@linghuist-v2/prisma": ["libs/prisma/index.ts"],
      "@linghuist-v2/supabase": ["libs/supabase/index.ts"]
    },
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@linghuist-v2/source"]
  }
}
