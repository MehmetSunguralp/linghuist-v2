{
  "name": "@linghuist-v2/linghuist-v2-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@linghuist-v2/linghuist-v2"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/linghuist-v2-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@linghuist-v2/linghuist-v2:build",
          "@linghuist-v2/linghuist-v2:serve"
        ]
      }
    }
  }
}
